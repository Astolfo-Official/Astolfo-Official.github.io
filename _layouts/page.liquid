---
layout: default
---
{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<div class="post{% if page.related_publications %} post--related-publications{% endif %}">
  {% if page.related_publications %}
    <header class="page-hero research-detail-hero">
      <h1>{{ page.title }}</h1>
      <p>{{ page.description }}</p>
    </header>
  {% else %}
    <header class="post-header page-standard-header">
      <h1 class="post-title">{{ page.title }}</h1>
      <p class="post-description">{{ page.description }}</p>
    </header>
  {% endif %}

  <article{% if page.related_publications %} class="research-detail-content"{% endif %}>
    {{ content }}
  </article>

  {% if page.related_publications %}
    <div class="related-publications publications-page">
      <div class="publications">
        {% bibliography --query @*[research_area={{page.research_area}}] %}
      </div>
    </div>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const relatedEntries = Array.from(document.querySelectorAll(".related-publications .bibliography > li"));
        if (relatedEntries.length === 0) return;

        const assignFallbackNumbers = () => {
          const relatedCount = relatedEntries.length;
          relatedEntries.forEach((entry, index) => {
            const numberElement = entry.querySelector(".publication-number");
            if (numberElement) numberElement.textContent = relatedCount - index;
          });
        };

        fetch("{{ '/publications/' | relative_url }}")
          .then((response) => {
            if (!response.ok) throw new Error("Could not load publications page");
            return response.text();
          })
          .then((html) => {
            const documentParser = new DOMParser();
            const publicationsDocument = documentParser.parseFromString(html, "text/html");
            const publicationEntries = Array.from(publicationsDocument.querySelectorAll(".bibliography > li"));
            if (publicationEntries.length === 0) throw new Error("No publication entries found");
            const publicationCount = publicationEntries.length;
            const publicationNumbersByKey = new Map();

            publicationEntries.forEach((entry, index) => {
              const publicationKey = entry.querySelector(".publication-entry-column")?.id;
              if (publicationKey) publicationNumbersByKey.set(publicationKey, publicationCount - index);
            });

            let assignedCount = 0;
            relatedEntries.forEach((entry) => {
              const publicationKey = entry.querySelector(".publication-entry-column")?.id;
              const numberElement = entry.querySelector(".publication-number");
              if (publicationKey && numberElement && publicationNumbersByKey.has(publicationKey)) {
                numberElement.textContent = publicationNumbersByKey.get(publicationKey);
                assignedCount += 1;
              }
            });

            if (assignedCount === 0) assignFallbackNumbers();
          })
          .catch(assignFallbackNumbers);
      });
    </script>
  {% endif %}

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>

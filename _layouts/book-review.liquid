---
layout: default
---
{% assign year = page.started | date: '%Y' %}
{% assign tags = page.tags | join: '' %}
{% assign categories = page.categories | join: '' %}
{% assign intro = content | split: 'Introduction:' | last | replace: '</li>', '' | replace: '</ul>', '' | markdownify | strip_html | strip_newlines | replace: '  ', ' ' | replace: '  ', ' ' | strip %}

{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<div class="post note-detail">
  <nav class="note-detail-back" aria-label="Notes navigation">
    <a href="{{ '/notes/' | relative_url }}"><i class="fa-solid fa-arrow-left-long" aria-hidden="true"></i> Notes</a>
  </nav>

  <header class="note-detail-hero">
    <div class="note-detail-cover-wrap">
      {% if page.cover %}
        <img class="note-detail-cover" alt="{{ page.title }} cover" src="{{ page.cover | relative_url }}">
      {% elsif page.olid %}
        <img class="note-detail-cover" alt="{{ page.title }} cover" src="https://covers.openlibrary.org/b/olid/{{ page.olid }}-L.jpg?default=false">
      {% elsif page.isbn %}
        <img class="note-detail-cover" alt="{{ page.title }} cover" src="https://covers.openlibrary.org/b/isbn/{{ page.isbn }}-L.jpg?default=false">
      {% else %}
        <span class="note-detail-cover-fallback">
          <i class="fa-solid fa-book-open" aria-hidden="true"></i>
        </span>
      {% endif %}
    </div>

    <div class="note-detail-copy">
      <div class="note-card-meta note-detail-meta">
        {% if page.status %}
          <span class="note-status note-status-{{ page.status | downcase }}">{{ page.status }}</span>
        {% endif %}
        {% if page.released %}
          <span>{{ page.released }}</span>
        {% endif %}
        {% if page.categories %}
          {% for category in page.categories %}
            {% unless category == 'notes' %}
              <span>{{ category }}</span>
            {% endunless %}
          {% endfor %}
        {% endif %}
      </div>

      <h1 class="post-title note-detail-title">{{ page.title }}</h1>

      {% if intro != '' %}
        <p class="note-detail-description">{{ intro }}</p>
      {% endif %}

      <div class="note-detail-actions">
        {% if page.buy_link %}
          <a class="note-detail-primary" href="{{ page.buy_link }}" target="_blank" rel="noopener noreferrer">
            <i class="fa-brands fa-github" aria-hidden="true"></i> Repository
          </a>
        {% endif %}
        <a class="note-detail-secondary" href="{{ '/notes/' | relative_url }}">
          <i class="fa-solid fa-layer-group" aria-hidden="true"></i> All notes
        </a>
      </div>
    </div>
  </header>

  <dl class="note-detail-facts" aria-label="Note metadata">
    {% if page.started %}
      <div>
        <dt>Started</dt>
        <dd>{{ page.started | date: '%b %-d, %Y' }}</dd>
      </div>
    {% endif %}
    {% if page.finished %}
      <div>
        <dt>Finished</dt>
        <dd>{{ page.finished | date: '%b %-d, %Y' }}</dd>
      </div>
    {% endif %}
    {% if tags != '' %}
      <div>
        <dt>Tags</dt>
        <dd>
          {% for tag in page.tags %}
            <a href="{{ tag | slugify | prepend: '/books/tag/' | relative_url }}">#{{ tag }}</a>{% unless forloop.last %}, {% endunless %}
          {% endfor %}
        </dd>
      </div>
    {% endif %}
    {% if categories != '' %}
      <div>
        <dt>Fields</dt>
        <dd>
          {% for category in page.categories %}
            {% unless category == 'notes' %}
              <a href="{{ category | slugify | prepend: '/books/category/' | relative_url }}">{{ category }}</a>{% unless forloop.last %}, {% endunless %}
            {% endunless %}
          {% endfor %}
        </dd>
      </div>
    {% endif %}
  </dl>

  <article class="note-detail-content">
    {% if intro != '' %}
      <h2>Overview</h2>
      <p>{{ intro }}</p>
    {% endif %}
  </article>

  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>

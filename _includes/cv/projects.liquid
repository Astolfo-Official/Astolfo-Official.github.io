{% comment %}
  Unified projects entry renderer for both formats
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    <li class="list-group-item">
      {% assign project_title = entry.name | default: entry.label %}
      {% if entry.url %}
        <h6 class="title font-weight-bold">
          <a href="{{ entry.url }}" target="_blank">{{ project_title }}</a>
        </h6>
      {% else %}
        <h6 class="title font-weight-bold">{{ project_title }}</h6>
      {% endif %}

      {% assign project_summary = entry.summary | default: entry.description | default: entry.details %}
      {% if project_summary %}
        <p>{{ project_summary | markdownify | remove: '<p>' | remove: '</p>' }}</p>
      {% endif %}

      {% if entry.highlights %}
        <ul class="items">
          {% for item in entry.highlights %}
            <li>
              <span class="item">{{ item | markdownify | remove: '<p>' | remove: '</p>' }}</span>
            </li>
          {% endfor %}
        </ul>
      {% endif %}
    </li>
  {% endfor %}
</ul>

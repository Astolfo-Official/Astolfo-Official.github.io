---
layout: default
---
{% assign year = page.date | date: '%Y' %}
{% assign tags = page.tags | join: '' %}
{% assign categories = page.categories | join: '' %}
{% assign url_beginning = page.url | slice: 0, 6 %}
{% if page.external_source == blank %}
  {% assign read_time = content | number_of_words | divided_by: 180 | plus: 1 %}
{% else %}
  {% assign read_time = page.feed_content | strip_html | number_of_words | divided_by: 180 | plus: 1 %}
{% endif %}

{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

<div class="post blog-post-detail">
  {% if url_beginning == '/blog/' %}
    <nav class="blog-post-back" aria-label="Blog navigation">
      <a href="{{ '/blog/' | relative_url }}"><i class="fa-solid fa-arrow-left-long" aria-hidden="true"></i> Blog</a>
    </nav>
  {% endif %}

  <header class="blog-post-hero">
    <p class="blog-post-eyebrow">Research Notebook</p>
    <h1 class="post-title">{{ page.title }}</h1>
    {% if page.description %}
      <p class="blog-post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <dl class="blog-post-facts" aria-label="Post metadata">
    <div>
      <dt>Published</dt>
      <dd>{{ page.date | date: '%b %-d, %Y' }}</dd>
    </div>
    <div>
      <dt>Reading Time</dt>
      <dd>{{ read_time }} min</dd>
    </div>
    {% assign last_date = page.last_modified_at | default: page.last_updated %}
    {% if last_date %}
      <div>
        <dt>Updated</dt>
        <dd>{{ last_date | date: '%b %-d, %Y' }}</dd>
      </div>
    {% endif %}
    {% if page.author %}
      <div>
        <dt>Author</dt>
        <dd>{{ page.author }}</dd>
      </div>
    {% endif %}
  </dl>

  <div class="blog-post-tags">
    {% if url_beginning == '/blog/' %}
      <a href="{{ year | prepend: '/blog/' | relative_url }}"><i class="fa-solid fa-calendar fa-sm"></i>{{ year }}</a>
    {% else %}
      <span><i class="fa-solid fa-calendar fa-sm"></i>{{ year }}</span>
    {% endif %}
    {% if tags != '' %}
      {% for tag in page.tags %}
        {% if url_beginning == '/blog/' %}
          <a href="{{ tag | slugify | prepend: '/blog/tag/' | relative_url }}"><i class="fa-solid fa-hashtag fa-sm"></i>{{ tag }}</a>
        {% else %}
          <span><i class="fa-solid fa-hashtag fa-sm"></i>{{ tag }}</span>
        {% endif %}
      {% endfor %}
    {% endif %}
    {% if categories != '' %}
      {% for category in page.categories %}
        {% if url_beginning == '/blog/' %}
          <a href="{{ category | slugify | prepend: '/blog/category/' | relative_url }}"><i class="fa-solid fa-tag fa-sm"></i>{{ category }}</a>
        {% else %}
          <span><i class="fa-solid fa-tag fa-sm"></i>{{ category }}</span>
        {% endif %}
      {% endfor %}
    {% endif %}
  </div>

  <article class="post-content blog-post-content">
    {% if page.toc and page.toc.beginning %}
      <div id="table-of-contents">
        {% toc %}
      </div>
      <hr>
    {% endif %}
    <div id="markdown-content">
      {{ content }}
    </div>
  </article>

  {% if page.citation %}
    {% include citation.liquid %}
  {% endif %}

  {% if page.related_publications %}
    <h2>References</h2>
    <div class="publications">
      {% bibliography --group_by none --cited_in_order %}
    </div>
  {% endif %}

  {% comment %}
  related_posts section intentionally disabled
  {% endcomment %}

  {% if site.disqus_shortname and page.disqus_comments %}
    {% include disqus.liquid %}
  {% endif %}
  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>
